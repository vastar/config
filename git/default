[core]
	fileMode = false
	autocrlf = input
	editor = nvim -f
	pager = nvim -R
[diff]
	tool = codediff
[difftool]
	prompt = false
[difftool "codediff"]
	cmd = nvim \"$LOCAL\" \"$REMOTE\" +\"CodeDiff file $LOCAL $REMOTE\"
[merge]
	tool = codediff
[mergetool]
	prompt = false
	keepBackup = false
[mergetool "codediff"]
	cmd = nvim \"$MERGED\" -c \"CodeDiff merge \\\"$MERGED\\\"\"
[init]
	defaultBranch = main
